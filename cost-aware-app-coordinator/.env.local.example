# Variabili di ambiente per cost-aware-app-coordinator
# Copia in .env.local (non commitare) o esporta in ~/.bashrc

# ── Dashboard ──────────────────────────────────────────────────────────────────
# URL base della dashboard Next.js
SKILL_DASHBOARD_URL=http://localhost:3001

# Versione skill (se non rilevata automaticamente da SKILL.md)
# SKILL_VERSION=1.0.0

# ── External routing (opt-in, DISABILITATO DI DEFAULT) ────────────────────────
# Leggi references/external-routing.md prima di attivare.
# MAI per codice di prodotto, credenziali, dati personali.
EXTERNAL_ROUTER_ENABLED=false

# Target: deepseek | openrouter
EXTERNAL_ROUTER_TARGET=deepseek

# API key OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
